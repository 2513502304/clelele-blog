---
import HomeSider from '@components/layout/HomeSider.astro';
import StyleGalleryBrowser from '@components/style-gallery/StyleGalleryBrowser';
import Cover from '@components/ui/cover/Cover.astro';
import { CONTENT_PADDING } from '@constants/layout';
import { siteConfig } from '@constants/site-config';
import Layout from '@layouts/Layout.astro';
import TwoColumnLayout from '@layouts/TwoColumnLayout.astro';
import { getStyleGalleryData, toStyleGalleryCardDataList } from '@lib/style-gallery';
import { Icon } from 'astro-icon/components';
import { getLocaleFromUrl, localizedPath, t } from '@/i18n';

export const prerender = false;

const locale = getLocaleFromUrl(Astro.url.pathname);
const gallery = await getStyleGalleryData();
const cardItems = toStyleGalleryCardDataList(gallery);
const tags = gallery.tags;
const title = `${t(locale, 'gallery.title')} | ${siteConfig.title}`;
const description = t(locale, 'gallery.description');
const galleryBasePath = localizedPath('/image-style-prompt-gallery', locale);
const exampleOverviewPath = localizedPath('/image-style-prompt-gallery/examples', locale);
const browserLabels = {
  searchPlaceholder: t(locale, 'gallery.searchPlaceholder'),
  allTags: t(locale, 'gallery.allTags'),
  sortItems: t(locale, 'gallery.sortItems'),
  sortDefault: t(locale, 'gallery.sortDefault'),
  sortImportedAt: t(locale, 'gallery.sortImportedAt'),
  sortTitle: t(locale, 'gallery.sortTitle'),
  sortExampleCount: t(locale, 'gallery.sortExampleCount'),
  sortAscending: t(locale, 'gallery.sortAscending'),
  sortDescending: t(locale, 'gallery.sortDescending'),
  imageCount: t(locale, 'gallery.imageCount', { count: '{count}' }),
  copy: t(locale, 'gallery.copy'),
  copied: t(locale, 'gallery.copied'),
  copyRetry: t(locale, 'gallery.copyRetry'),
  view: t(locale, 'gallery.view'),
  noMatches: t(locale, 'gallery.noMatches'),
};
Astro.response.headers.set('Cache-Control', 'public, s-maxage=30, stale-while-revalidate=300');
---

<Layout title={title} description={description}>
  <TwoColumnLayout>
    <Cover slot="cover" title={t(locale, 'gallery.title')} />
    <HomeSider slot="sider" />
    <div class={`bg-gradient-start shadow-box tablet:shadow-none flex flex-col gap-6 overflow-hidden ${CONTENT_PADDING.standard}`}>
      <header class="relative overflow-hidden rounded-lg border border-rose-100 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-950">
        <div class="absolute top-0 right-0 h-32 w-32 rounded-bl-full bg-rose-100/60 dark:bg-rose-950/30"></div>
        <div class="relative grid grid-cols-[1fr_auto] gap-6 md:grid-cols-1">
          <div class="space-y-3">
            <p class="flex items-center gap-2 text-sm font-bold text-rose-500">
              <Icon name="ri:sparkling-2-line" class="size-4" />
              {t(locale, 'gallery.kicker')}
            </p>
            <h1 class="text-balance font-black text-4xl leading-tight text-gray-950 md:text-3xl dark:text-white">
              {t(locale, 'gallery.title')}
            </h1>
            <p class="max-w-3xl text-pretty text-base leading-8 text-gray-600 dark:text-gray-300">
              {description}
            </p>
          </div>
          <div class="flex min-w-36 flex-col justify-end rounded-lg bg-gray-950 p-4 text-white dark:bg-white dark:text-gray-950">
            <span class="text-4xl font-black">{cardItems.length}</span>
            <span class="text-xs font-bold uppercase tracking-wider opacity-70">{t(locale, 'gallery.items')}</span>
            <a href={exampleOverviewPath} data-astro-prefetch="false" class="mt-3 inline-flex items-center gap-1 border-white/20 border-t pt-3 text-xs font-bold transition hover:text-rose-300 dark:border-gray-300 dark:hover:text-rose-600">
              <Icon name="ri:gallery-view-2" class="size-4" />
              {t(locale, 'gallery.subGallery')}
            </a>
          </div>
        </div>
      </header>

      <StyleGalleryBrowser client:idle items={cardItems} tags={tags} galleryBasePath={galleryBasePath} labels={browserLabels} />
    </div>
  </TwoColumnLayout>
</Layout>
