---
import PageLayout from '@layouts/PageLayout.astro';
import { fetchCharacterQuote } from '@lib/character-quote';
import AboutContent from './AboutContent.md';
import CharacterQuote from './CharacterQuote.astro';

const DEFAULT_CHARACTER = 'Yukino Yukinoshita';
const FALLBACK_QUOTE = "People who don't work hard don't have the right to be envious of the people with talent.";

const character = process.env.ANIME_QUOTE_CHARACTER?.trim() || DEFAULT_CHARACTER;
const characterLabel = process.env.ANIME_QUOTE_CHARACTER_LABEL?.trim();
let quote = FALLBACK_QUOTE;
let displayedCharacter = characterLabel || character;

try {
  const result = await fetchCharacterQuote(character, { retries: 1, timeoutMs: 3_000 });
  quote = result.quote;
  displayedCharacter = characterLabel || result.character;
} catch (error) {
  console.warn(`[character-quote] Falling back to the bundled quote for ${character}.`, error);
}

const frontmatter = {
  title: 'About',
  coverTitle: '关于clelele',
  description: '关于clelele',
};
---

<PageLayout frontmatter={frontmatter}>
  <h2>你好，这里是 clelele</h2>
  <CharacterQuote character={displayedCharacter} quote={quote} />
  <AboutContent />
</PageLayout>
