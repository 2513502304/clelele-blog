# ANALYZE=true
BLOG_PORT=4321

# Yurippe character query. Its full quote collection is cached per warm server instance for 30 days.
# The optional label only changes the displayed attribution.
ANIME_QUOTE_CHARACTER="Yukino Yukinoshita"
ANIME_QUOTE_CHARACTER_LABEL="雪之下雪乃"

# Image Style Prompt Gallery GitHub login. Register a GitHub OAuth App and point its callback to:
# https://your-domain.example/api/style-gallery/auth/github/callback
# Public OAuth App identifier.
STYLE_GALLERY_GITHUB_CLIENT_ID=
# Server-only OAuth App secret.
STYLE_GALLERY_GITHUB_CLIENT_SECRET=
# Must exactly match the callback configured in the corresponding GitHub OAuth App.
STYLE_GALLERY_GITHUB_REDIRECT_URI=
# Signs the 14-day login cookie. Keep it independent from every other token and at least 32 characters.
# Generate one with: openssl rand -base64 48
STYLE_GALLERY_SESSION_SECRET=

# Image Style Prompt Gallery writes and Hugging Face S3 storage.
STYLE_GALLERY_UPLOAD_TOKEN=
HF_S3_ACCESS_KEY_ID=
HF_S3_SECRET_ACCESS_KEY=
HF_S3_ENDPOINT=https://s3.hf.co/clelele0722
HF_S3_BUCKET=raw-datasets
STYLE_GALLERY_BUCKET_PREFIX=image-style-prompt-gallery
STYLE_GALLERY_SIGNED_URL_TTL_SECONDS=86400
HF_S3_REGION=us-east-1
